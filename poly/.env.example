# Weather Underground API 密钥
WU_API_KEY=your_wu_api_key_here

# obs 拉取间隔（秒），默认 60
WU_POLL_INTERVAL_SECONDS=60

# obs 数据质量阈值
OBS_MAX_SECOND_AGE_MINUTES=23
OBS_MIN_GAP_MINUTES=9

# 交易参数（均值-2 档口）
OFFSET_MINUS_2_PRICE=0.98
OFFSET_MINUS_2_SIZE=200

# 交易参数（均值-1 档口）
OFFSET_MINUS_1_PRICE=0.90
OFFSET_MINUS_1_SIZE=200

# 交易检查间隔（秒），默认 60
TRADE_CHECK_INTERVAL_SECONDS=60

# Polymarket 签名类型
# 2=GNOSIS_SAFE（MetaMask/Rabby 浏览器钱包登录，最常见）
# 1=POLY_PROXY（邮箱/Google Magic Link 登录）
# 0=EOA（独立 EOA 钱包）
SIGNATURE_TYPE=2

# 钱包解密密码（可选，不填则启动时交互式输入）
# 生产环境建议留空，通过交互式输入避免密码暴露在环境变量中
# POLY_MASTER_PASSWORD=
